{
  "storageTypes": ["platformStorage"],
  "entrypoint": "src/index.js",
  "requiredInternals": [],
  "configuration": {
    "fields": {
      "url":      { "type": "string",  "default": "http://localhost:4001",           "description": "rqlite HTTP API URL" },
      "raftPort": { "type": "number",  "default": 4002,                              "description": "Raft consensus port" },
      "dataDir":  { "type": "string",  "default": "var-pryv/rqlite-data",            "description": "rqlite data directory" },
      "binPath":  { "type": "string",  "default": "var-pryv/rqlite-bin/rqlited",     "description": "rqlited binary path" }
    }
  },
  "scripts": {
    "setup": "scripts/setup",
    "start": "scripts/start"
  }
}
