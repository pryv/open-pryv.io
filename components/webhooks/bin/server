#!/usr/bin/env node

// Plan 38 — observability boot must come before any other require.
require('../../../bin/_observability-boot');

// Service that receives notifications from api-server and send them to existing Webhooks.

const Application = require('../src/application');

// Start the app
startup();

async function startup () {
  // new config has to be loadded before the application

  const app = new Application();
  await app.setup();

  await app.run();
}
