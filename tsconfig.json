{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": [
      "es2022",
      "DOM"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "maxNodeModuleJsDepth": 0
  },
  "include": [
    "components/**/*.ts",
    "components/**/*.js",
    "storages/**/*.ts",
    "storages/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/node_modules",
    "**/*.test.js",
    "**/*.test.ts",
    "**/test/**",
    "bin/**",
    "config/plugins/**"
  ]
}
